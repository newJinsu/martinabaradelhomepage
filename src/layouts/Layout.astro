---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  lang: string;
  description?: string;
}

const {
  title,
  lang,
  description = "Martina Baradel - Sociologist & Criminologist out of UK.",
} = Astro.props;

// 언어 변경 시 현재 머물고 있는 하위 페이지 경로를 유지하는 함수
const getPath = (targetLang: string) => {
  const path = Astro.url.pathname;
  if (path === '/' || path === '') return `/${targetLang}/`;
  return path.replace(/^\/(en|it|jp)(\/|$)/, `/${targetLang}/`);
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Martina Baradel, Yakuza, Sociologist, Criminologist, Oxford, Nagoya University, Japanese Studies
      , Mako Nishimura, inagawa-kai, Yamaguchi-gumi, 21st Century Yakuza, Yakuza Blues"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- Google Fonts Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <header class="header">
      <div class="container header-content">
        <a href={`/${lang}/`} class="logo">Martina Baradel</a>
        <nav class="nav">
          <a href={`/${lang}/`}>About</a>
          <a href={`/${lang}/research`}>Research</a>
          <a href={`/${lang}/books`}>Publications</a>
          <div class="lang-switcher">
            <a href={getPath("en")} class={lang === "en" ? "active" : ""}>EN</a> |
            <a href={getPath("it")} class={lang === "it" ? "active" : ""}>IT</a> |
            <a href={getPath("jp")} class={lang === "jp" ? "active" : ""}>JP</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer-content">
        <p>
          &copy; {new Date().getFullYear()} Martina Baradel. All rights reserved.
        </p>
        <div class="social-links">
          <a href="mailto:#" aria-label="Email">
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path><polyline points="22,6 12,13 2,6"></polyline></svg
            >
          </a>
          <a
            href="#"
            aria-label="Instagram"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg
            >
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .header {
    background-color: var(--color-header-bg);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .nav {
    display: flex;
    gap: 2rem;
  }

  .nav a {
    color: #ffffff;
    font-size: 1rem;
    font-weight: 500;
  }

  .nav a:hover,
  .nav a.active {
    color: var(--color-accent);
  }

  .lang-switcher {
    margin-left: 1rem;
    color: var(--color-text-muted);
  }

  .lang-switcher a {
    font-size: 0.9rem;
    padding: 0 0.2rem;
  }

  .footer {
    background-color: var(--color-header-bg);
    color: #ffffff;
    padding: 2rem 0;
    font-size: 0.9rem;
    border-top: 2px solid var(--color-accent);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .social-links a {
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      color 0.3s ease,
      transform 0.2s ease;
  }

  .social-links a:hover {
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  @media screen and (max-width: 768px) {
    .header-content {
      flex-direction: column;
      gap: 1rem;
    }
    .nav {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }
    .footer-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
